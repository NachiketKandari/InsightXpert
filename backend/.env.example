# =============================================================================
# InsightXpert — Environment Configuration
# Copy to .env.local and fill in your values
# =============================================================================

# --- LLM Provider -----------------------------------------------------------
# Choose: "gemini" or "ollama"
LLM_PROVIDER=gemini

# --- Gemini (when LLM_PROVIDER=gemini) --------------------------------------
GEMINI_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# --- Ollama (when LLM_PROVIDER=ollama) --------------------------------------
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434

# --- Database ----------------------------------------------------------------
# Local SQLite (default):
DATABASE_URL=sqlite:///./insightxpert.db

# --- ChromaDB (RAG vector store) --------------------------------------------
CHROMA_PERSIST_DIR=./chroma_data

# --- CORS --------------------------------------------------------------------
# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,https://insightxpert.vercel.app,https://insightxpert-ai.web.app

# --- Auth / Admin seed -------------------------------------------------------
ADMIN_SEED_EMAIL=admin@insightxpert.ai
ADMIN_SEED_PASSWORD=changeme

# --- Agent -------------------------------------------------------------------
MAX_AGENT_ITERATIONS=10
SQL_ROW_LIMIT=1000
SQL_TIMEOUT_SECONDS=30

# --- Startup / Runtime -------------------------------------------------------
RAG_BOOTSTRAP_TIMEOUT_SECONDS=120
CONVERSATION_TTL_SECONDS=7200

# --- Logging -----------------------------------------------------------------
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG

# --- Observability (Day 2+) --------------------------------------------------
OBS_DATABASE_PATH=./obs.db
