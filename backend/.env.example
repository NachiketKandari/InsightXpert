# =============================================================================
# InsightXpert — Environment Configuration
# Copy this file to .env.local and fill in your values.
# Lines starting with # are comments — remove the # to activate a setting.
# =============================================================================

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Google Gemini API key — get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# JWT signing secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-ME-replace-with-a-random-64-char-hex-string

# ── LLM PROVIDER ─────────────────────────────────────────────────────────────

# Which LLM backend to use: gemini | ollama | vertex_ai  (default: gemini)
LLM_PROVIDER=gemini

# Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Ollama — local models, no API key needed (https://ollama.com)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# Vertex AI (GCP Model Garden)
# LLM_PROVIDER=vertex_ai
# GCP_PROJECT_ID=your-gcp-project-id
# VERTEX_AI_REGION=global
# VERTEX_AI_MODEL=zai-org/glm-5-maas

# ── DATABASE ─────────────────────────────────────────────────────────────────

# SQLAlchemy DB URL — SQLite is the default; no changes needed for local dev
# DATABASE_URL=sqlite:///./insightxpert.db

# ── CHROMADB (RAG VECTOR STORE) ───────────────────────────────────────────────

# Directory where ChromaDB persists data (relative to backend/)
# CHROMA_PERSIST_DIR=./chroma_data

# ── AUTH & ADMIN SEED USER ────────────────────────────────────────────────────
# These credentials are auto-created on first startup.
# Change ADMIN_SEED_PASSWORD before deploying publicly.

ADMIN_SEED_EMAIL=admin@insightxpert.ai
ADMIN_SEED_PASSWORD=changeme-use-a-strong-password

# JWT token lifetime in minutes (default: 1440 = 24 hours)
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins
# CORS_ORIGINS=http://localhost:3000

# ── AGENT TUNING ─────────────────────────────────────────────────────────────

# Max LLM tool-call iterations per request (default: 10)
# MAX_AGENT_ITERATIONS=10

# Max enrichment sub-tasks spawned by the orchestrator (default: 5)
# MAX_ORCHESTRATOR_TASKS=5

# Max rows returned per SQL query (default: 10000)
# SQL_ROW_LIMIT=10000

# SQL execution timeout in seconds (default: 30)
# SQL_TIMEOUT_SECONDS=30

# Python sandbox execution timeout for quant_analyst (default: 10)
# PYTHON_EXEC_TIMEOUT_SECONDS=10

# ── STARTUP / RUNTIME ────────────────────────────────────────────────────────

# Max seconds to wait for RAG seeding before continuing startup (default: 120)
# RAG_BOOTSTRAP_TIMEOUT_SECONDS=120

# In-memory conversation TTL in seconds (default: 7200 = 2 hours)
# CONVERSATION_TTL_SECONDS=7200

# Set to false to disable pre-computed stats context injection into prompts
# ENABLE_STATS_CONTEXT=true

# ── LOGGING ──────────────────────────────────────────────────────────────────

# DEBUG | INFO | WARNING | ERROR  (default: INFO)
LOG_LEVEL=INFO
