    {
      "id": "chunk-types-label",
      "type": "text",
      "x": 771.1849442790144,
      "y": 5.999026728915908,
      "width": 320,
      "height": 180,
      "text": "SSE ChatChunk Types:\n\nstatus       - Agent progress indicator\ntool_call    - Tool invocation + reasoning\nsql          - Generated SQL query\ntool_result  - Query results (JSON)\nanswer       - Final analyst text\ninsight      - Enriched synthesized text\nclarification - Needs user input\norchestrator_plan - Enrichment tasks\nagent_trace  - Sub-task execution record\nmetrics      - Tokens + timing\n[DONE]       - Stream complete",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "seed": 171,
      "version": 134,
      "versionNonce": 1932671072,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772539305714,
      "link": null,
      "locked": false,
      "groupIds": [],
      "index": "b09",
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null,
      "containerId": null,
      "originalText": "SSE ChatChunk Types:\n\nstatus       - Agent progress indicator\ntool_call    - Tool invocation + reasoning\nsql          - Generated SQL query\ntool_result  - Query results (JSON)\nanswer       - Final analyst text\ninsight      - Enriched synthesized text\nclarification - Needs user input\norchestrator_plan - Enrichment tasks\nagent_trace  - Sub-task execution record\nmetrics      - Tokens + timing\n[DONE]       - Stream complete",
      "autoResize": true,
      "lineHeight": 1.153846153846154
    },
